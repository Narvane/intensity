# Copy to deploy/.env.demo on the VPS (never commit .env.demo)
# Same GHCR image as production; isolated DB + JWT secret.

API_IMAGE=ghcr.io/owner/intensity/api:latest

# Public hostnames (must also be set in deploy/.env for Caddy TLS)
DEMO_API_DOMAIN=demo-intensity-api.narvane.com.br
DEMO_APP_DOMAIN=demo-intensity.narvane.com.br

# PostgreSQL (demo only — do not reuse production passwords)
POSTGRES_DB=intensity_demo
POSTGRES_USER=intensity
POSTGRES_PASSWORD=change-me-demo-postgres

# JWT — must differ from production INTENSITY_JWT_SECRET
INTENSITY_JWT_SECRET=change-me-demo-jwt-secret-at-least-32-chars
