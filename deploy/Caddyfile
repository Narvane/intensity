{
	email {$ACME_EMAIL}
}

{$API_DOMAIN} {
	reverse_proxy api:8080
}

{$APP_DOMAIN} {
	@wellknown path /.well-known/*
	handle @wellknown {
		root * /srv/deep-link
		file_server
	}

	# Password-reset landing (email links). Production app domain has no SPA.
	@passwordReset path /auth/reset-password*
	handle @passwordReset {
		root * /srv/deep-link
		rewrite * /auth/reset-password.html
		file_server
	}

	@privacy path /privacy /privacy-policy /privacy/*
	handle @privacy {
		root * /srv/deep-link
		rewrite * /privacy/index.html
		file_server
	}

	@deleteAccount path /delete-account /delete-account/*
	handle @deleteAccount {
		root * /srv/deep-link
		rewrite * /delete-account/index.html
		file_server
	}

	respond "Intensity invite links open in the mobile app." 404
}

# Optional demo sites — written by ./deploy-demo.sh into snippets/
import /etc/caddy/snippets/*.caddy
